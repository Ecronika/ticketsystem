# Azubi Werkzeug Tracker - Environment Variables
# Copy this file to .env and adjust values as needed.

# --- Core Configuration ---
# Path to the directory where data (DB, signatures, reports) is stored.
# Default: ./azubi_werkzeug (inside the application folder)
DATA_DIR=/data

# Secret key for session signing. 
# CRITICAL: Keep this secret! If not set, a random key is generated/loaded from secret.key.
SECRET_KEY=change_me_to_a_long_random_string

# --- Database ---
# Path to the SQLite database file.
# Default: {DATA_DIR}/werkzeug.db (or instance/werkzeug.db)
DB_PATH=/data/werkzeug.db

# --- Security ---
# Set to 'production' to disable debug mode.
FLASK_ENV=production

# --- Optional ---
# Rate limiting storage URL (memory is default)
# RATELIMIT_STORAGE_URL=redis://localhost:6379
