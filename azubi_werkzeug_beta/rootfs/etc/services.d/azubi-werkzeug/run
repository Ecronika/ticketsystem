#!/usr/bin/with-contenv bashio
# ==============================================================================
# Home Assistant Add-on: Azubi Werkzeug Tracker
# Starts the Azubi Werkzeug Tracker application
# ==============================================================================

bashio::log.info "Starte Azubi Werkzeug Tracker..."

# Wechsel ins Arbeitsverzeichnis
cd /app || bashio::exit.nok "Kann nicht nach /app wechseln"

# Datenbank initialisieren
bashio::log.info "Initialisiere Datenbank..."
python3 -c "from app import setup_database; setup_database()" \
    || bashio::exit.nok "Datenbank-Initialisierung fehlgeschlagen"

# SSL Konfiguration lesen
SSL=$(bashio::config 'ssl')
CERTFILE=$(bashio::config 'certfile')
KEYFILE=$(bashio::config 'keyfile')

# Pruefe ob SSL aktiviert ist
if bashio::var.true "${SSL}"; then
    bashio::log.info "SSL ist aktiviert."
    
    CERTFILE_PATH="/ssl/${CERTFILE}"
    KEYFILE_PATH="/ssl/${KEYFILE}"

    if [ ! -f "${CERTFILE_PATH}" ] || [ ! -f "${KEYFILE_PATH}" ]; then
        bashio::log.warning "Zertifikate (${CERTFILE_PATH} / ${KEYFILE_PATH}) nicht gefunden!"
        bashio::log.warning "Generiere temporäres (Self-Signed) Zertifikat für lokalen Zugriff..."
        openssl req -new -newkey rsa:4096 -days 3650 -nodes -x509 \
            -subj "/C=DE/ST=Berlin/L=Berlin/O=Local/CN=localhost" \
            -keyout "/data/adhoc_key.pem" \
            -out "/data/adhoc_cert.pem" 2>/dev/null
        CERTFILE_PATH="/data/adhoc_cert.pem"
        KEYFILE_PATH="/data/adhoc_key.pem"
        bashio::log.info "Temporäres Zertifikat erstellt: ${CERTFILE_PATH}"
    else
        bashio::log.info "Nutze vorhandene Zertifikate:"
        bashio::log.info "Zertifikat: ${CERTFILE_PATH}"
        bashio::log.info "Key: ${KEYFILE_PATH}"
    fi
    
    # Server starten mit SSL (Optimized for SD Card / Stability)
    bashio::log.info "Starte Gunicorn Server mit SSL auf Port 5000..."
    exec gunicorn \
        --workers 1 \
        --threads 2 \
        --worker-class gthread \
        --timeout 120 \
        --graceful-timeout 120 \
        --keep-alive 5 \
        --max-requests 1000 \
        --max-requests-jitter 50 \
        --bind 0.0.0.0:5000 \
        --certfile "${CERTFILE_PATH}" \
        --keyfile "${KEYFILE_PATH}" \
        --access-logfile - \
        --error-logfile - \
        app:app
else
    bashio::log.info "SSL ist deaktiviert."
    
    # Server starten ohne SSL (Optimized for SD Card / Stability)
    bashio::log.info "Starte Gunicorn Server auf Port 5000..."
    exec gunicorn \
        --workers 1 \
        --threads 2 \
        --worker-class gthread \
        --timeout 120 \
        --graceful-timeout 120 \
        --keep-alive 5 \
        --max-requests 1000 \
        --max-requests-jitter 50 \
        --bind 0.0.0.0:5000 \
        --access-logfile - \
        --error-logfile - \
        app:app
fi
